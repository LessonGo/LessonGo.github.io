.post-block {
  background: #ffffff;
  border-radius: 8px;
  padding: 30px;
  margin-bottom: 40px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.post-title {
  font-size: 28px;
  font-weight: 600;
}

.post-meta {
  color: #888;
  font-size: 14px;
}

.post-button .btn {
  background: #2d2d2d;
  border-radius: 4px;
}